/* 全局样式 — 吃灰计算器 */

/* 引入 TDesign 主题变量 */
@import './miniprogram_npm/tdesign-miniprogram/common/style/theme/_index.wxss';

page {
  --font-stack: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Helvetica Neue", sans-serif;
  font-family: var(--font-stack);
  font-size: 28rpx;
  line-height: 1.5;
  background-color: var(--td-bg-color-page, #F2F2F7);
  color: var(--td-text-color-primary, #1D1D1F);
  -webkit-font-smoothing: antialiased;
  padding-bottom: 100rpx; /* 为自定义 tabBar 留出空间 */
}

/* 深浅模式适配 */
@media (prefers-color-scheme: dark) {
  page {
    background-color: #000000;
    color: #F5F5F7;
  }
}

/* 通用工具类 */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }
.gap-8 { gap: 8rpx; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.text-center { text-align: center; }
.text-secondary { color: var(--td-text-color-secondary, #6E6E73); }
.text-tertiary { color: var(--td-text-color-placeholder, #8E8E93); }
.font-mono { font-family: "SF Mono", Menlo, Consolas, monospace; }
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 安全区适配 */
.safe-bottom { padding-bottom: constant(safe-area-inset-bottom); padding-bottom: env(safe-area-inset-bottom); }

/* 颜色变量 */
page {
  --color-blue: #007AFF;
  --color-red: #FF3B30;
  --color-orange: #FF9500;
  --color-green: #34C759;
  --color-purple: #AF52DE;
  --color-blue-bg: #E5F0FF;
  --color-red-bg: #FFEEED;
  --color-orange-bg: #FFF4E5;
  --color-green-bg: #E9F7ED;
}

@media (prefers-color-scheme: dark) {
  page {
    --color-blue: #0A84FF;
    --color-red: #FF453A;
    --color-orange: #FF9F0A;
    --color-green: #30D158;
    --color-purple: #BF5AF2;
    --color-blue-bg: #1A2A44;
    --color-red-bg: #3A1C1C;
    --color-orange-bg: #3A2C1A;
    --color-green-bg: #1A3320;
  }
}
