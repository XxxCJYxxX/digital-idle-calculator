/* pages/stats/stats.wxss */

.page-stats {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* 概览卡片 */
.stats-summary {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.stat-card {
  flex: 1;
  background-color: var(--td-bg-color-container, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}
@media (prefers-color-scheme: dark) {
  .stat-card { background-color: #1C1C1E; }
}
.stat-card-label {
  display: block;
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #6E6E73);
}
.stat-card-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-top: 6rpx;
  letter-spacing: -0.5rpx;
}
