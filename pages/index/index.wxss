/* pages/index/index.wxss */

.page-index {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* 概览统计 */
.summary-bar {
  display: flex;
  background-color: var(--td-bg-color-container, #FFFFFF);
  border-radius: 24rpx;
  padding: 20rpx 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}
@media (prefers-color-scheme: dark) {
  .summary-bar { background-color: #1C1C1E; }
}

.summary-item {
  flex: 1;
  text-align: center;
}
.summary-label {
  display: block;
  font-size: 22rpx;
  color: var(--td-text-color-secondary, #6E6E73);
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}
.summary-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-top: 4rpx;
  letter-spacing: -0.5rpx;
}
.text-danger { color: #FF3B30; }
@media (prefers-color-scheme: dark) {
  .text-danger { color: #FF453A; }
}

/* 工具栏 */
.toolbar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.toolbar-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: var(--td-bg-color-container, #FFFFFF);
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
  max-width: 200rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
@media (prefers-color-scheme: dark) {
  .toolbar-picker { background-color: #1C1C1E; }
}

.toolbar-spacer { flex: 1; }

.toolbar-action {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background-color: var(--td-bg-color-container, #FFFFFF);
  color: var(--td-text-color-secondary, #6E6E73);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
@media (prefers-color-scheme: dark) {
  .toolbar-action { background-color: #1C1C1E; }
}
.toolbar-action-hover { opacity: 0.6; }
.toolbar-action-danger { color: #FF3B30; }
@media (prefers-color-scheme: dark) {
  .toolbar-action-danger { color: #FF453A; }
}

/* 设备列表 */
.device-list {
  padding-bottom: 40rpx;
}

/* FAB */
.fab {
  position: fixed;
  bottom: 180rpx;
  right: 40rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background-color: #007AFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 122, 255, 0.3);
  z-index: 99;
  transition: transform 0.15s, opacity 0.15s;
}
@media (prefers-color-scheme: dark) {
  .fab { background-color: #0A84FF; }
}
.fab-hover {
  transform: scale(0.92);
  opacity: 0.85;
}
