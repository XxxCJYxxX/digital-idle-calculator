/* components/chart-bar/chart-bar.wxss */

.chart-wrap {
  background-color: var(--td-bg-color-container, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}
@media (prefers-color-scheme: dark) {
  .chart-wrap {
    background-color: #1C1C1E;
    box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.3);
  }
}

.chart-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  letter-spacing: -0.3rpx;
}

.chart-canvas {
  display: block;
  width: 100%;
}
